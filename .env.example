# ── UrbanThread mobile ─────────────────────────────────────────────────────
# Copy to `.env` and point it at a reachable backend. This file is committed;
# `.env` is not.

# Root of the API, including the version prefix. No trailing slash.
#
# `localhost` means "this device", so it never reaches a backend running on
# your workstation. Use:
#   Android emulator   http://10.0.2.2:5000/api/v1
#   iOS simulator      http://localhost:5000/api/v1
#   Physical device    http://<your-lan-ip>:5000/api/v1
API_BASE_URL=http://10.0.2.2:5000/api/v1

# Origin the backend bakes into uploaded image URLs — the value of SERVER_URL
# in the backend's own .env. Those URLs are absolute, so a backend configured
# with http://localhost:5000 hands the phone links it cannot resolve. The app
# rewrites this origin to the one implied by API_BASE_URL; see MediaUrl.
MEDIA_ORIGIN_OVERRIDE=http://localhost:5000

# Seconds. Applied to connect, send and receive independently.
CONNECT_TIMEOUT=15
RECEIVE_TIMEOUT=30

# Logs every request/response body when true. Leave false outside development —
# it prints access tokens.
ENABLE_HTTP_LOGGING=true
